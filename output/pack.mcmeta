{"\u0070\u0061\u0063\u006b":{"\u0070\u0061\u0063\u006b\u005f\u0066\u006f\u0072\u006d\u0061\u0074":15,"\u0064\u0065\u0073\u0063\u0072\u0069\u0070\u0074\u0069\u006f\u006e":{"\u0063\u006f\u006c\u006f\u0072":"\u0067\u006f\u006c\u0064","\u0074\u0065\u0078\u0074":"\u2694\u0020\u004e\u006f\u0064\u0065\u004d\u0043\u0020\u5e55\u5e9c\u65f6\u4ee3\u0020"},"\u0073\u0075\u0070\u0070\u006f\u0072\u0074\u0065\u0064\u005f\u0066\u006f\u0072\u006d\u0061\u0074\u0073":{"\u006d\u0069\u006e\u005f\u0069\u006e\u0063\u006c\u0075\u0073\u0069\u0076\u0065":13,"\u006d\u0061\u0078\u005f\u0069\u006e\u0063\u006c\u0075\u0073\u0069\u0076\u0065":32767}},"\u006f\u0076\u0065\u0072\u006c\u0061\u0079\u0073":{"\u0065\u006e\u0074\u0072\u0069\u0065\u0073":[{"\u0066\u006f\u0072\u006d\u0061\u0074\u0073":{"\u006d\u0069\u006e\u005f\u0069\u006e\u0063\u006c\u0075\u0073\u0069\u0076\u0065":36,"\u006d\u0061\u0078\u005f\u0069\u006e\u0063\u006c\u0075\u0073\u0069\u0076\u0065":99},"\u0064\u0069\u0072\u0065\u0063\u0074\u006f\u0072\u0079":"\u0031\u005f\u0032\u0031\u005f\u0032","\u006d\u0069\u006e\u005f\u0066\u006f\u0072\u006d\u0061\u0074":[36,0],"\u006d\u0061\u0078\u005f\u0066\u006f\u0072\u006d\u0061\u0074":[99,0]},{"\u0066\u006f\u0072\u006d\u0061\u0074\u0073":{"\u006d\u0069\u006e\u005f\u0069\u006e\u0063\u006c\u0075\u0073\u0069\u0076\u0065":24,"\u006d\u0061\u0078\u005f\u0069\u006e\u0063\u006c\u0075\u0073\u0069\u0076\u0065":1000},"\u0064\u0069\u0072\u0065\u0063\u0074\u006f\u0072\u0079":"\u0031\u005f\u0032\u0030\u005f\u0035\u005f\u0072\u0065\u006d\u006f\u0076\u0065\u005f\u0073\u0068\u0075\u006c\u006b\u0065\u0072\u005f\u0068\u0065\u0061\u0064\u005f\u006f\u0076\u0065\u0072\u006c\u0061\u0079","\u006d\u0069\u006e\u005f\u0066\u006f\u0072\u006d\u0061\u0074":[24,0],"\u006d\u0061\u0078\u005f\u0066\u006f\u0072\u006d\u0061\u0074":[1000,0]},{"\u0066\u006f\u0072\u006d\u0061\u0074\u0073":{"\u006d\u0069\u006e\u005f\u0069\u006e\u0063\u006c\u0075\u0073\u0069\u0076\u0065":42,"\u006d\u0061\u0078\u005f\u0069\u006e\u0063\u006c\u0075\u0073\u0069\